
[[ -x /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"

# PATH setup moved to the top so it's fully in place even if a later
# block (antidote/compinit/fzf init) stalls and gets Ctrl+C'd.
export PATH="$HOME/bin:$PATH"
export PATH="$HOME/.npm-global/bin:$PATH"
export PATH="$HOME/go/bin:$PATH"
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
  export PATH="$HOME/.local/bin:$PATH"
fi

[[ -f ~/.zsh/aliases.zsh ]] && source ~/.zsh/aliases.zsh
[[ -f ~/.zsh/functions.zsh ]] && source ~/.zsh/functions.zsh
[[ -f ~/.zsh/starship.zsh ]] && source ~/.zsh/starship.zsh
[[ -f ~/.zsh/nvm.zsh ]] && source ~/.zsh/nvm.zsh
[[ -f ~/.zsh/wsl2fix.zsh ]] && source ~/.zsh/wsl2fix.zsh
[[ -f ~/.config/secrets/.env ]] && set -a && source ~/.config/secrets/.env
set +a

# Load Starship
eval "$(starship init zsh)"

eval "$(zoxide init zsh)"

export EDITOR=nvim
export VISUAL=nvim

# sudoplz askpass helper — lets agents run `sudo -A` instead of failing on the password prompt
command -v askpass >/dev/null 2>&1 && export SUDO_ASKPASS="$(command -v askpass)"

HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE EXTENDED_HISTORY

# Vulkan SDK
export VULKAN_SDK=~/VulkanSDK/1.4.328.0/macOS
export PATH="$VULKAN_SDK/bin:$PATH"
export DYLD_LIBRARY_PATH="$VULKAN_SDK/lib:$DYLD_LIBRARY_PATH"
export VK_ADD_LAYER_PATH="$VULKAN_SDK/share/vulkan/explicit_layer.d"
export PKG_CONFIG_PATH="$VULKAN_SDK/lib/pkgconfig:$PKG_CONFIG_PATH"

# Targetprocess MCP auth via macOS Keychain
export TP_BASE_URL=https://tecplot.tpondemand.com
if command -v security >/dev/null 2>&1; then
  __tp_token=$(security find-generic-password -a "$USER" -s targetprocess_api_token -w 2>/dev/null)
  [[ -n "$__tp_token" ]] && export TP_ACCESS_TOKEN="$__tp_token"
  unset __tp_token
fi

if [[ -f /opt/homebrew/opt/antidote/share/antidote/antidote.zsh ]]; then
  source /opt/homebrew/opt/antidote/share/antidote/antidote.zsh
elif [[ -f ${ZDOTDIR:-~}/.antidote/antidote.zsh ]]; then
  source ${ZDOTDIR:-~}/.antidote/antidote.zsh
fi
antidote load ${ZDOTDIR:-$HOME}/.zsh_plugins.txt

autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# fzf shell integration (Ctrl+R history, Ctrl+T file picker, Alt+C cd)
source <(fzf --zsh)

[[ "$TERM_PROGRAM" == "kiro" ]] && . "$(kiro --locate-shell-integration-path zsh)"

# Audio: wine and yabridge
export WINEESYNC=1
export WINEFSYNC=1
export PATH="$PATH:$HOME/.local/share/yabridge"


# Added by Antigravity CLI installer
export PATH="/home/marc/.local/bin:$PATH"
