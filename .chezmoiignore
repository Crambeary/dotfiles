.config/nvim/plugin/packer_compiled.lua

# Generated antidote bundle — .zshrc rebuilds it from .zsh_plugins.txt on demand
.zsh_plugins.zsh

# fish-managed universal vars: fish rewrites this itself; tracking it across
# machines just accumulates dead per-host paths. Each machine owns its own.
.config/fish/fish_variables

# Repo docs, not a dotfile target
README.md

# Secrets: never let chezmoi track/add this, regardless of `chezmoi add` habits
.config/secrets/**

# Mac and Linux only 
{{ if eq .chezmoi.os "windows" }}
.config/alacritty/alacritty.toml
{{ end }}

# Windows only. The PowerShell profile stays tracked in source so Windows
# still gets it — it's just not a target anywhere else.
{{ if ne .chezmoi.os "windows" }}
AppData/Roaming/alacritty/alacritty.toml
AppData/*
scoop/*
Documents/WindowsPowerShell/**
{{ end }}

# Fish is used in the Linux/WSL environment, not native Windows.
{{ if eq .chezmoi.os "windows" }}
.config/fish/**
{{ end }}


# macOS only files
{{ if ne .chezmoi.os "darwin" }}
.aerospace.toml
{{ end }}

# Karabiner: macOS only, and this mac's live config is the source of truth
{{ if ne .chezmoi.os "darwin" }}
.config/karabiner/**
{{ end }}

# mpv stream listener: runs only on marc-fedora (the SSH host side of the
# RemoteForward tunnel, playing audio streamed back from marc-mac-fedora)
{{ if ne .chezmoi.hostname "marc-fedora" }}
.config/systemd/user/mpv-stream-listen.service
.local/bin/mpv-stream-listen.sh
{{ end }}

# SSH RemoteForward stanza for marc-fedora: only needed on marc-mac-fedora,
# the machine that initiates the connection and listens locally on 6600
{{ if ne .chezmoi.hostname "marc-mac-fedora" }}
.ssh/config.d/chezmoi
{{ end }}

# KDE Plasma (Linux only)
{{ if ne .chezmoi.os "linux" }}
.config/plasma*
.config/kwin*
.config/kde*
.config/kglobalshortcutsrc
.config/kcminputrc
.config/ksplashrc
{{ end }}

# KDE session-state churn (desktop UUIDs, popup geometry px, screen res) -
# not real config, just noise on every login
.config/kwinrc
.config/plasma-org.kde.plasma.desktop-appletsrc
