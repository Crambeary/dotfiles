#!/bin/bash
# Merges the statusLine key into ~/.claude/settings.json without touching
# other machine-specific keys (model, effortLevel, tui, voice, theme, etc).
# Re-runs automatically (via run_onchange) whenever this script's content changes.
# script hash: {{ include "dot_claude/executable_statusline-command.sh" | sha256sum }}
set -euo pipefail

SETTINGS="$HOME/.claude/settings.json"
mkdir -p "$HOME/.claude"

if [ ! -f "$SETTINGS" ]; then
  echo '{}' > "$SETTINGS"
fi

tmp=$(mktemp)
jq '.statusLine = {"type":"command","command":"bash ~/.claude/statusline-command.sh"}' "$SETTINGS" > "$tmp"
mv "$tmp" "$SETTINGS"
